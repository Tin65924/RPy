{
  "version": "2.0",
  "src": "src",
  "out": "out",
  "flags": {
    "typed": false,
    "fast": false,
    "no_runtime": false
  },
  "exclude": [
    "__pycache__",
    "*.pyc"
  ],
  "rojo_mapping": {
    "server": "ServerScriptService",
    "client": "StarterPlayerScripts",
    "shared": "ReplicatedStorage"
  },
  "sync_command": "rojo build"
}
